---
/**
 * nidus — custom single sidebar.
 *
 * Icon-led, collapsible sections. Each top-level group is a native <details>
 * accordion: click the section to reveal its pages. The section holding the
 * current page is open on load. No right-hand TOC, no column dividers — the
 * sidebar's own ground tone separates it, not a border.
 */
import { Icon } from "@astrojs/starlight/components";
import PageToc from "./PageToc.astro";

const { sidebar, toc } = Astro.locals.starlightRoute;

// Flatten the page's table of contents into a single list (keeping depth for
// indentation) and drop the synthetic "Overview" entry. Rendered under the
// active page link as the sidebar's second tier.
function flattenToc(items) {
  return items.flatMap((i) => [i, ...flattenToc(i.children ?? [])]);
}
const tocItems = (toc?.items ? flattenToc(toc.items) : []).filter(
  (i) => i.slug !== "_top",
);

// Section → icon. Keyed by the group label set in astro.config's `sidebar`.
const ICONS = {
  "Start here": "rocket",
  Guides: "open-book",
  "HTTP API": "laptop",
  Reference: "list-format",
};

/** Does this entry (or any descendant) point at the current page? */
function hasCurrent(entry) {
  if (entry.type === "link") return entry.isCurrent;
  return entry.entries.some(hasCurrent);
}
---

<nav class="nd-nav" aria-label="Documentation" transition:animate="none">
  <ul class="nd-nav__list">
    {
      sidebar.map((entry) =>
        entry.type === "group" ? (
          <li class:list={["nd-group", { "is-active": hasCurrent(entry) }]}>
            <details class="nd-details" open={hasCurrent(entry)}>
              <summary class="nd-summary">
                <span class="nd-summary__icon">
                  <Icon name={ICONS[entry.label] ?? "open-book"} size="1.1em" />
                </span>
                <span class="nd-summary__label">{entry.label}</span>
                <span class="nd-summary__chev">
                  <Icon name="right-caret" size="1em" />
                </span>
              </summary>
              <ul class="nd-sublist">
                {entry.entries.map((sub) =>
                  sub.type === "link" ? (
                    <li>
                      <a
                        href={sub.href}
                        class:list={["nd-link", { "is-current": sub.isCurrent }]}
                        aria-current={sub.isCurrent ? "page" : undefined}
                      >
                        {sub.label}
                      </a>
                      {sub.isCurrent && <PageToc items={tocItems} />}
                    </li>
                  ) : (
                    <li class="nd-subgroup">
                      <span class="nd-subgroup__label">{sub.label}</span>
                      <ul class="nd-sublist">
                        {sub.entries.map(
                          (leaf) =>
                            leaf.type === "link" && (
                              <li>
                                <a
                                  href={leaf.href}
                                  class:list={[
                                    "nd-link",
                                    { "is-current": leaf.isCurrent },
                                  ]}
                                  aria-current={
                                    leaf.isCurrent ? "page" : undefined
                                  }
                                >
                                  {leaf.label}
                                </a>
                              </li>
                            ),
                        )}
                      </ul>
                    </li>
                  ),
                )}
              </ul>
            </details>
          </li>
        ) : (
          <li>
            <a
              href={entry.href}
              class:list={[
                "nd-link nd-link--solo",
                { "is-current": entry.isCurrent },
              ]}
              aria-current={entry.isCurrent ? "page" : undefined}
            >
              {entry.label}
            </a>
            {entry.isCurrent && <PageToc items={tocItems} />}
          </li>
        ),
      )
    }
  </ul>
</nav>

<script>
  // Scroll-spy for the in-sidebar page TOC. Highlights the section you're
  // reading as you scroll, but a click on a TOC entry always wins: the clicked
  // entry is pinned active until you actually scroll again (wheel/touch/keys).
  // That's the only way to disambiguate — a short trailing section can't scroll
  // its heading to the top, so several links resolve to the same bottom scroll
  // position and position alone can't tell which one you clicked.
  // Re-runs on every view-transition navigation via `astro:page-load`.
  let teardownTocSpy: (() => void) | null = null;

  function initTocSpy() {
    teardownTocSpy?.(); // drop the previous page's listeners
    teardownTocSpy = null;

    const links = Array.from(
      document.querySelectorAll(".nd-toc__link"),
    ) as HTMLAnchorElement[];
    if (!links.length) return;

    // Heading targets in document order (tops increase down the page).
    const entries: { link: HTMLAnchorElement; target: HTMLElement }[] = [];
    for (const link of links) {
      const id = decodeURIComponent(new URL(link.href).hash.slice(1));
      const target = id ? document.getElementById(id) : null;
      if (target) entries.push({ link, target });
    }
    if (!entries.length) return;
    const last = entries[entries.length - 1].link;

    let active: HTMLAnchorElement | null = null;
    const setActive = (link: HTMLAnchorElement | undefined) => {
      if (!link || link === active) return;
      active?.classList.remove("is-active");
      link.classList.add("is-active");
      active = link;
    };

    const atBottom = () =>
      window.innerHeight + window.scrollY >=
      document.documentElement.scrollHeight - 2;

    // The section you're reading is the last heading scrolled up past the top
    // band (~top 28% of the viewport). At the very bottom the final heading may
    // sit below that band with nothing left to scroll, so pin the last entry.
    const fromScroll = () => {
      if (atBottom()) return setActive(last);
      const line = window.innerHeight * 0.28;
      let current = entries[0].link;
      for (const { link, target } of entries) {
        if (target.getBoundingClientRect().top > line) break;
        current = link;
      }
      setActive(current);
    };

    // A click expresses intent directly — pin it and stop tracking scroll until
    // the user scrolls of their own accord.
    let pinned = false;
    let raf = 0;
    const nav = document.querySelector(".nd-nav");
    const onClick = (e: Event) => {
      const a = (e.target as Element | null)?.closest(".nd-toc__link");
      if (!a) return;
      pinned = true;
      setActive(a as HTMLAnchorElement);
    };
    const onScroll = () => {
      if (pinned || raf) return;
      raf = requestAnimationFrame(() => {
        raf = 0;
        fromScroll();
      });
    };
    const release = () => {
      if (!pinned) return;
      pinned = false;
      fromScroll();
    };

    nav?.addEventListener("click", onClick);
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("wheel", release, { passive: true });
    window.addEventListener("touchmove", release, { passive: true });
    window.addEventListener("keydown", release);

    teardownTocSpy = () => {
      if (raf) cancelAnimationFrame(raf);
      nav?.removeEventListener("click", onClick);
      window.removeEventListener("scroll", onScroll);
      window.removeEventListener("wheel", release);
      window.removeEventListener("touchmove", release);
      window.removeEventListener("keydown", release);
    };

    // Land on a deep-linked heading as pinned; otherwise track scroll position.
    const hashed = location.hash
      ? entries.find((e) => e.link.hash === location.hash)
      : null;
    if (hashed) {
      pinned = true;
      setActive(hashed.link);
    } else {
      fromScroll();
    }
  }

  document.addEventListener("astro:page-load", initTocSpy);
</script>
